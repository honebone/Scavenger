  tutorials:
  - title: "tips\uFF1A\u7C21\u6613\u8868\u793A\u306E\u5207\u308A\u66FF\u3048"
    tutorialText: "\u753B\u9762\u53F3\u4E0B\u306E\u30C8\u30B0\u30EB\u304B\u3089\u3001<color=#FFBF69>\u7C21\u6613\u8868\u793A\u306EON/OFF\u3092\u5207\u308A\u66FF\u3048\u308B\u3053\u3068\u304C\u3067\u304D\u308B</color>\r\n\r\n<color=#FFBF69>\u7C21\u6613\u8868\u793A\u3067\u306F</color>\u3001\u88C5\u5099\u54C1\u30FB\u30AD\u30E3\u30E9\u306E\u7279\u6027\u30FB\u72B6\u614B\u7570\u5E38\u306E\u60C5\u5831\u304C<color=#FFBF69>\u7C21\u6613\u7684\u306A\u8AAC\u660E\u306B\u7F6E\u304D\u63DB\u308F\u3063\u3066</color>\u8868\u793A\u3055\u308C\u3066\u3044\u308B\r\n\r\n\u7C21\u6613\u8868\u793A\u306F\u6982\u8981\u304C\u7C21\u6F54\u306B\u793A\u3055\u308C\u3066\u3044\u308B\u305F\u3081\u5206\u304B\u308A\u3084\u3059\u3044\u304C\u3001<color=#FFBF69>\u5177\u4F53\u7684\u306A\u6570\u5024\u306B\u95A2\u3059\u308B\u8A18\u8F09\u304C\u306A\u3044</color>\u305F\u3081\u3001\u3088\u308A\u8A73\u7D30\u306A\u60C5\u5831\u3092\u78BA\u8A8D\u3059\u308B\u306B\u306F\u7C21\u6613\u8868\u793A\u3092OFF\u306B\u3059\u308B\u5FC5\u8981\u304C\u3042\u308B"
    left: 1
    guideObj: {fileID: 5566588964595943442, guid: fa912de34ba1d9646b5bf66b4f3f6caf, type: 3}
