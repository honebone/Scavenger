  tutorials:
  - title: "\u5BFF\u547D"
    tutorialText: "\u30D7\u30EC\u30A4\u30E4\u30FC\u304C\u53EC\u559A\u3059\u308B\u30AD\u30E3\u30E9\u306E\u307B\u3068\u3093\u3069\u306F<color=#FFBF69>\u5BFF\u547D</color>\u3092\u6301\u3063\u3066\u3044\u308B\n<color=#FFBF69>\u5BFF\u547D</color>\u3092\u6301\u3064\u30AD\u30E3\u30E9\u306F\u3001\u30E9\u30A6\u30F3\u30C9\u7D42\u4E86\u6642\u306B<sprite
      name=HP><color=#87FF79>HP</color>\u3092\u5931\u3046\n\n\u5931\u3046\u91CF\u306F\u57FA\u790E<sprite
      name=maxHP><color=#87FF79>maxHP</color>\u306E1/[<color=#FFBF69>\u5BFF\u547D</color>]\u306B\u7B49\u3057\u3044(\u7AEF\u6570\u5207\u308A\u4E0A\u3052)\n\n\u30D2\u30F3\u30C8\uFF1A<sprite
      name=HP>\u6E1B\u5C11\u91CF\u306F\u57FA\u790E<sprite name=maxHP>\u3092\u53C2\u7167\u3057\u3066\u3044\u308B\u305F\u3081\u3001\u53EC\u559A\u4F53\u306E<sprite
      name=maxHP>\u3092\u5897\u52A0\u3055\u305B\u308B\u3088\u3046\u306A\u80FD\u529B\u306F\u3001\u53EC\u559A\u4F53\u304C\u3088\u308A\u9577\u3044\u30E9\u30A6\u30F3\u30C9\u3092\u6226\u3048\u308B\u3088\u3046\u306B\u306A\u308B\u3053\u3068\u3092\u610F\u5473\u3059\u308B"
