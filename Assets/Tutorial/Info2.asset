  tutorials:
  - title: "\u30AD\u30E3\u30E9\u30AF\u30BF\u30FC\u8A73\u7D30"
    tutorialText: "\u753B\u9762\u53F3\u5074\u306B\u3001\u30AD\u30E3\u30E9\u30AF\u30BF\u30FC\u306E\u8A73\u7D30\u304C\u8868\u793A\u3055\u308C\u3066\u3044\u308B"
    left: 1
    guideObj: {fileID: 0}
  - title: "\u30AD\u30E3\u30E9\u30AF\u30BF\u30FC\u8A73\u7D30"
    tutorialText: "HP\uFF1A\u4F53\u529B\u30000\u306B\u306A\u308B\u3068\u6B7B\u4EA1\u3059\u308B\nSAN\uFF1A\u6B63\u6C17\u5EA6\u30000\u306B\u306A\u308B\u3068...?\n\nATK\uFF1A\u653B\u6483\u529B\nCRIT\uFF1A\u30AF\u30EA\u30C6\u30A3\u30AB\u30EB\u3000\u653B\u6483\u6642\u306B\u4E00\u5B9A\u306E\u78BA\u7387\u3067\u5927\u30C0\u30E1\u30FC\u30B8\u3092\u4E0E\u3048\u308B\n\nEVD\uFF1A\u56DE\u907F\u7387\u3000EVD\uFF05\u306E\u78BA\u7387\u3067\u653B\u6483\u3092\u56DE\u907F\u3059\u308B\nACC\uFF1A\u547D\u4E2D\u7387\u3000ACC\uFF05\u306E\u78BA\u7387\u3067\u653B\u6483\u304C\u547D\u4E2D\u3059\u308B\nACT\uFF1A\u884C\u52D5\u5024\u3000ACT\u304C\u5927\u304D\u3044\u3068\u30BF\u30FC\u30F3\u304C\u65E9\u304F\u56DE\u3063\u3066\u304D\u3084\u3059\u304F\u306A\u308B"
    left: 1
    guideObj: {fileID: 0}
  - title: "\u60C5\u5831\u306E\u8868\u793A"
    tutorialText: "\u30AD\u30E3\u30E9\u30AF\u30BF\u30FC\u306B\u9650\u3089\u305A\u3001\u30A2\u30D3\u30EA\u30C6\u30A3\u3084\u30DC\u30BF\u30F3\u306A\u3069\u306E\u69D8\u3005\u306A\u3082\u306E\u304C\u53F3\u30AF\u30EA\u30C3\u30AF\u3067\u8A73\u7D30\u3092\u78BA\u8A8D\u3067\u304D\u308B\n\n\u6C17\u306B\u306A\u308B\u3082\u306E\u304C\u3042\u3063\u305F\u3089\u7A4D\u6975\u7684\u306B\u53F3\u30AF\u30EA\u30C3\u30AF\u3057\u3088\u3046"
    left: 1
    guideObj: {fileID: 0}
  - title: "\u51FA\u6483"
    tutorialText: "\"\u51FA\u6483\"\u30DC\u30BF\u30F3\u3092\u62BC\u3057\u3066\u63A2\u7D22\u3092\u59CB\u3081\u308B"
    left: 1
    guideObj: {fileID: 3781821200645693970, guid: 49f78ca43bd993c4e93e92a2b23aa256, type: 3}
