  tutorials:
  - title: "\u7DE8\u6210\u306E\u30B3\u30C4"
    tutorialText: "\u30D1\u30FC\u30C6\u30A3\u7DE8\u6210\u306E\u969B\u306F\u3001\u4EE5\u4E0B\u306E\u3053\u3068\u306B\u6C17\u3092\u4ED8\u3051\u308B\u3068\u826F\u3044\n\n<color=#FFBF69>\u25CB\u30BF\u30F3\u30AF\u5F79\u3001\u653B\u6483\u5F79\u3001\u56DE\u5FA9\u5F79\u306F\u3044\u308B\u304B\n\u25CB\u5404\u30AD\u30E3\u30E9\u304C\u5F97\u610F\u306A\u5217\u306B\u914D\u7F6E\u3055\u308C\u3066\u3044\u308B\u304B\n\u25CB\u524D\u30FB\u4E2D\u5217\u305D\u308C\u305E\u308C\u306B\u30AD\u30E3\u30E9\u3092\u5C11\u306A\u304F\u3068\u30821\u4F53\u306F\u914D\u7F6E\u3057\u3066\u3044\u308B\u304B</color>\n(\u8AB0\u3082\u3044\u306A\u3044\u5217\u304C\u3042\u308B\u3068\u3001\u30AD\u30E3\u30E9\u306F\u81EA\u52D5\u7684\u306B\u5217\u3092\u8A70\u3081\u3066\u3057\u307E\u3046)"
    left: 0
    guideObj: {fileID: 0}
