  key: madness
  tutorials:
  - title: "\u72C2\u6C17"
    tutorialText: "\u30D7\u30EC\u30A4\u30E4\u30FC\u304C\u7CBE\u795E\u5D29\u58CA\u3059\u308B\u305F\u3073\u3001\u72C2\u6C17\u304C1\u5897\u52A0\u3059\u308B(\u6700\u59275)\n\n\u72C2\u6C17\u304C\u5897\u52A0\u3059\u308B\u3068\u3001<color=#CA0000>\u72C2\u6C17\u306E\u7279\u6027</color>\u304C1\u3064\u89E3\u653E\u3055\u308C\u308B\n\n\u6575\u306F\u4E00\u5B9A\u78BA\u7387\u3067<color=#CA0000>\u72C2\u6C17\u306E\u7279\u6027</color>\u3092\u5F97\u305F\u72B6\u614B\u3067\u51FA\u73FE\u3059\u308B\n(\u30DC\u30B9\u3092\u9664\u304F)\n(\u65751\u4F53\u304C\u8907\u6570\u306E<color=#CA0000>\u72C2\u6C17\u306E\u7279\u6027</color>\u3092\u6301\u3064\u3053\u3068\u306F\u306A\u3044)\n\n<color=#CA0000>\u72C2\u6C17\u306E\u7279\u6027</color>\u3092\u5F97\u305F\u6575\u306F\u30B9\u30C6\u30FC\u30BF\u30B9\u304C\u5927\u5E45\u306B\u5897\u52A0\u3057\u3001\u3055\u3089\u306B\u7279\u6027\u306E\u7A2E\u985E\u306B\u5FDC\u3058\u305F\u5F37\u5316\u3082\u53D7\u3051\u308B"
    left: 0
    guideObj: {fileID: 0}
