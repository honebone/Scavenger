      name=CRIT><link=T_CRIT><u>CRIT</u></link></color>\r\n<color=#FFFF00><sprite
      name=ACT><link=T_ACT><u>ACT</u></link></color>\r\n<color=#FAED8A><sprite name=buff><link=S_\u6F5C\u4F0F><u>\u6F5C\u4F0F</u></link></color>\n<color=#FFFFFF><sprite
