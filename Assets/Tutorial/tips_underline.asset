  tutorials:
  - title: "tips\uFF1A\u30A2\u30F3\u30C0\u30FC\u30E9\u30A4\u30F3"
    tutorialText: "\u30C6\u30AD\u30B9\u30C8\u4E2D\u306E\u4E0B\u7DDA\u304C\u5F15\u304B\u308C\u305F\u7528\u8A9E\u306F\u3001<color=#FFBF69>\u30AB\u30FC\u30BD\u30EB\u3092\u5408\u308F\u305B\u308B</color>\u3053\u3068\u3067\u7528\u8A9E\u306E\u89E3\u8AAC\u3092\u898B\u308B\u3053\u3068\u304C\u3067\u304D\u308B\n\u4E0B\u306E\u7528\u8A9E\u306B\u30AB\u30FC\u30BD\u30EB\u3092\u5408\u308F\u305B\u3066\u78BA\u8A8D\u3057\u3066\u307F\u3088\u3046\n<color=#8DD1FF><sprite
      name=PROT><link=T_PROT><u>PROT</u></link></color>\r\n<color=#00FFFF><sprite
      name=shield><link=T_shield><u>\u30B7\u30FC\u30EB\u30C9</u></link></color>\r\n<color=#256CC8><sprite
      name=INT><link=T_INT><u>INT</u></link></color>\r\n<color=#C900FF><sprite name=debuff><link=S_\u30DE\u30FC\u30AF><u>\u30DE\u30FC\u30AF</u></link></color>\r\n<color=#FF6CC1><sprite
      name=ACC><link=T_ACC><u>ACC</u></link></color>\r\n<color=#C30000><sprite name=ATK><link=T_ATK><u>ATK</u></link></color>\r\n<color=#DD6300><sprite
